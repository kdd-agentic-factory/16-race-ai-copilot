# =============================================================================
# KDD Agentic Factory — RACE AI Copilot (Production)
# =============================================================================
# Application
APP_ENV=production
APP_NAME=kdd-race-ai-copilot
PORT=8110
LOG_LEVEL=INFO
HOST=0.0.0.0

# LLM / Ollama
OLLAMA_URL=http://ollama.kdd-agentic.svc.cluster.local:11434
COPILOT_DEFAULT_MODEL=qwen2.5:7b

# Internal service URLs (Kubernetes DNS)
MCP_GATEWAY_URL=http://02-mcp-gateway.kdd-agentic.svc.cluster.local:8001
RAG_CAG_URL=http://03-rag-cag-knowledge-layer.kdd-agentic.svc.cluster.local:8002
SKILLS_URL=http://04-skills-autoskills-registry.kdd-agentic.svc.cluster.local:8003
ORCHESTRATOR_URL=http://01-agent-orchestrator.kdd-agentic.svc.cluster.local:8000

# Vector database
QDRANT_URL=http://qdrant.kdd-agentic.svc.cluster.local:6333

# Database
DATABASE_URL=postgresql://kdd:kdd@postgres.kdd-agentic.svc.cluster.local:5432/kdd_copilot
POSTGRES_URL=${DATABASE_URL}

# Feature toggles
ENABLE_MOCK_MODE=false
ENABLE_APPROVAL_GUARD=true
ENABLE_EVIDENCE_GUARD=true

# Static files directory
STATIC_DIR=/app/static

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.kdd-observability.svc.cluster.local:4317

# CORS — restrict to command center frontend
CORS_ORIGINS=https://race.kdd-agentic.example.com
