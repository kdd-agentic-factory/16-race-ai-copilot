{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvidenceItem",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "url_or_path": {"type": "string"},
    "snippet": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "metadata": {"type": "object"}
  },
  "required": ["id", "title", "snippet", "confidence"],
  "definitions": {
    "EvidencePacket": {
      "type": "object",
      "properties": {
        "packet_id": {"type": "string"},
        "query": {"type": "string"},
        "items": {
          "type": "array",
          "items": {"$ref": "#"}
        },
        "groundedness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "citation_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": ["packet_id", "query", "items"]
    }
  }
}
